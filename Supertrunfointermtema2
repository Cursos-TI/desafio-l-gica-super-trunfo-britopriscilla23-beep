
#include <stdio.h>
#include <string.h>
#include <stdlib.h>

int main() {
    char estado1[26], estado2[26];
    char codigo1[10], codigo2[10];
    char cidade1[50], cidade2[50];
    int populacao1, populacao2;
    float area1, area2, pib1, pib2;
    int turismo1, turismo2;
    float densidade1, pib_per_capita1;
    float densidade2, pib_per_capita2;

    // Cadastro 1
    printf("Digite o estado 1: ");
    scanf("%s", estado1);

    printf("Digite o codigo 1: ");
    scanf("%s", codigo1);

    printf("Digite o nome da cidade 1: ");
    scanf("%49s", cidade1);

    printf("Digite a populacao 1: ");
    scanf("%d", &populacao1);

    printf("Digite a area 1: ");
    scanf("%f", &area1);

    printf("Digite o PIB 1: ");
    scanf("%f", &pib1);

    printf("Digite numero de pontos turisticos 1: ");
    scanf("%d", &turismo1);
    // calculo 1
        densidade1 = populacao1 / area1;
        pib_per_capita1 = pib1 * 1000000000 / populacao1;
        printf("Densidade populacional 1: %.2f habitantes/km²\n", densidade1);
        printf("PIB per capita 1: %.2f\n", pib_per_capita1);

    // Cadastro 2
    printf("\nDigite o estado 2: ");
    scanf("%s", estado2);

    printf("Digite o codigo 2: ");
    scanf("%s", codigo2);

    printf("Digite o nome da cidade 2: ");
    scanf("%49s", cidade2);

    printf("Digite a populacao 2: ");
    scanf("%d", &populacao2);

    printf("Digite a area 2: ");
    scanf("%f", &area2);

    printf("Digite o PIB 2: ");
    scanf("%f", &pib2);

    printf("Digite numero de pontos turisticos 2: ");
    scanf("%d", &turismo2);
    
    // calculo 2
        densidade2 = populacao2 / area2;
        pib_per_capita2 = pib2 * 1000000000 / populacao2;
        printf("Densidade populacional 2: %.2f habitantes/km²\n", densidade2);
        printf("PIB per capita 2: %.2f\n", pib_per_capita2);

    // Exibição
    printf("\n--- Dados Carta 1 ---\n");
    printf("Estado: %s\n", estado1);
    printf("Codigo: %s\n", codigo1);
    printf("Cidade: %s\n", cidade1);
    printf("Populacao: %d\n", populacao1);
    printf("Area: %.2f km²\n", area1);
    printf("PIB: %.2f bilhoes\n", pib1);
    printf("Turismo: %d\n", turismo1);

    printf("\n--- Dados Carta 2 ---\n");
    printf("Estado: %s\n", estado2);
    printf("Codigo: %s\n", codigo2);
    printf("Cidade: %s\n", cidade2);
    printf("Populacao: %d\n", populacao2);
    printf("Area: %.2f km²\n", area2);
    printf("PIB: %.2f bilhoes\n", pib2);
    printf("Turismo: %d\n", turismo2);

    //Soma dos valores das cartas
    float valor_total_carta1 = densidade1 + pib_per_capita1 + turismo1;
    float valor_total_carta2 = densidade2 + pib_per_capita2 + turismo2;


    // Comparações entre as cartas
  if (valor_total_carta1 > valor_total_carta2) {
        printf("\nCarta 1 é superior à Carta 2\n");
    } else if (valor_total_carta1 < valor_total_carta2) {
        printf("\nCarta 2 é superior à Carta 1\n");
    } else {
        printf("\nAs cartas são equivalentes\n");
    }
    // comparação de cada atributo com switch case
    printf("\nComparação de atributos:\n");
    printf("1. Densidade Populacional\n");
    printf("2. PIB per Capita\n");
    printf("3. Turismo\n");
    int escolha;
    printf("Escolha um atributo para comparar (1-3): ");
    scanf("%d", &escolha);
    switch (escolha) {
        case 1:
            if (densidade1 > densidade2) {
                printf("Carta 1 tem maior densidade populacional\n");
            } else if (densidade1 < densidade2) {
                printf("Carta 2 tem maior densidade populacional\n");
            } else {
                printf("As cartas têm a mesma densidade populacional\n");
            }
            break;
        case 2:
            if (pib_per_capita1 > pib_per_capita2) {
                printf("Carta 1 tem maior PIB per capita\n");
            } else if (pib_per_capita1 < pib_per_capita2) {
                printf("Carta 2 tem maior PIB per capita\n");
            } else {
                printf("As cartas têm o mesmo PIB per capita\n");
            }
            break;
        case 3:
            if (turismo1 > turismo2) {
                printf("Carta 1 tem mais pontos turísticos\n");
            } else if (turismo1 < turismo2) {
                printf("Carta 2 tem mais pontos turísticos\n");
            } else {
                printf("As cartas têm o mesmo número de pontos turísticos\n");
            }
            break;
        default:
            printf("Opção inválida\n");
    }
    

    return 0;
}
